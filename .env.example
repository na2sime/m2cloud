# ── Copy to .env for local development (docker-compose). .env is gitignored. ──
# In the cluster these come from AWS Secrets Manager via External Secrets Operator.

# Postgres (RDS in prod). Local = docker-compose service "postgres".
DATABASE_URL=postgres://m2cloud:m2cloud@localhost:5432/m2cloud

# Redis (in-cluster StatefulSet in prod). Local = docker-compose service "redis".
REDIS_URL=redis://localhost:6379

# RabbitMQ (in-cluster StatefulSet in prod). Local = docker-compose service "rabbitmq".
RABBITMQ_URL=amqp://m2cloud:m2cloud@localhost:5672

# JWT signing secret (HS256). NEVER commit a real value. From Secrets Manager in prod.
JWT_SECRET=dev-super-secret-change-me-0123456789

# Service ports
GATEWAY_PORT=3000
REALTIME_PORT=3001
WORKER_PORT=3002

# Frontend → backend URLs (used by web at build/runtime)
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3001

# Logging
LOG_LEVEL=info
